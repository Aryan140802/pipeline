stages:

  # ============== Validation and Initialization ============
  - stage: Validation_Stage
    displayName: Validation and Initialization
    pool:
      name: TFS-RH-1

    jobs:
      - job: Validation_Job
        displayName: Validation
        workspace:
          clean: all

        steps:

          - checkout: self
            path: s/app

          - checkout: git://devops_testing/eis-configuration@refs/heads/config
            path: s/eis-configurations

          - task: CmdLine@2
            name: val_task
            env:
              BRANCH: $(Build.SourceBranchName)
            displayName: Validating repository
            inputs:
              script: |
                set -e

                applicationName=$(ls -1 "$(Build.SourcesDirectory)/app" | grep -vE "Config|README.md|azure-pipelines.yml" | tail -n 1)
                echo "Application name : $applicationName"
                echo "branch: $BRANCH"

                # ── Detect PR targeting main ──────────────────────────────────
                TARGET_BRANCH="$(System.PullRequest.TargetBranch)"
                IS_PR_TO_MAIN="false"
                if [[ "$TARGET_BRANCH" == "refs/heads/main" || "$TARGET_BRANCH" == "main" ]]; then
                  IS_PR_TO_MAIN="true"
                fi
                echo "##vso[task.setvariable variable=IsPRToMain;isOutput=true]$IS_PR_TO_MAIN"
                echo "  PR targeting main: $IS_PR_TO_MAIN"

                if [ "$BRANCH" = "main" ]; then
                  echo "Branch is 'main' — skipping config validation"
                  echo "##vso[task.setvariable variable=DeployFlag;isOutput=true]false"
                  echo "##vso[task.setvariable variable=CacheFlag;isOutput=true]false"
                  exit 0
                fi

                CONFIG_FILE="$(Build.SourcesDirectory)/eis-configurations/${BRANCH}_config.yml"
                OVERRIDE_FILE="$(Build.SourcesDirectory)/eis-configurations/${BRANCH}_override.yml"

                echo ""
                echo "========= [3/3] Branch-specific config validation ========="

                if [ ! -f "$CONFIG_FILE" ]; then
                  echo "##[error] Config file not found: $CONFIG_FILE"
                  exit 1
                fi
                echo "  ✔ ${BRANCH}_config.yml — exists"

                if [ -f "$OVERRIDE_FILE" ]; then
                  echo "  ✔ ${BRANCH}_override.yml — exists"
                else
                  echo "  ℹ ${BRANCH}_override.yml — not found (optional, skipping)"
                fi

                echo ""
                echo "  Checking for duplicate application key in ${BRANCH}_config.yml..."
                COUNT=$(yq e "keys | map(select(. == \"$applicationName\")) | length" "$CONFIG_FILE")
                if [ "$COUNT" -gt 1 ]; then
                  echo "##[error] Config file '${BRANCH}_config.yml' has duplicate entries for key '$applicationName'."
                  exit 1
                fi
                echo "  ✔ No duplicate key for '$applicationName' in ${BRANCH}_config.yml"

                if [ -f "$OVERRIDE_FILE" ]; then
                  echo "  Checking for duplicate application key in ${BRANCH}_override.yml..."
                  COUNT=$(yq e "keys | map(select(. == \"$applicationName\")) | length" "$OVERRIDE_FILE")
                  if [ "$COUNT" -gt 1 ]; then
                    echo "##[error] Override file '${BRANCH}_override.yml' has duplicate entries for key '$applicationName'."
                    exit 1
                  fi
                  echo "  ✔ No duplicate key for '$applicationName' in ${BRANCH}_override.yml"
                fi

                echo ""
                echo "  Extracting config block for '$applicationName'..."

                if [ ! -d "$(Build.SourcesDirectory)/app/Config" ]; then
                  mkdir -p "$(Build.SourcesDirectory)/app/Config"
                fi

                yq e ".$applicationName | select(. != null)" \
                  "$(Build.SourcesDirectory)/eis-configurations/${BRANCH}_config.yml" \
                  > "$(Build.SourcesDirectory)/app/Config/config_eis_configuration.yml"

                if [ -s "$(Build.SourcesDirectory)/app/Config/config_eis_configuration.yml" ]; then
                  config_path="$(Build.SourcesDirectory)/app/Config/config_eis_configuration.yml"

                  echo "  Validating extracted config block for '$applicationName'..."
                  YQ_OUTPUT=$(yq e '.' "$config_path" 2>&1) || {
                    echo "##[error] YAML syntax error in extracted config block for '$applicationName':"
                    echo "$YQ_OUTPUT" | sed 's/^/    /'
                    exit 1
                  }
                  echo "  ✔ Extracted config block — syntax OK"

                elif [ -s "$(Build.SourcesDirectory)/app/Config/config.yml" ]; then
                  yq e ".$BRANCH" "$(Build.SourcesDirectory)/app/Config/config.yml" \
                    > "$(Build.SourcesDirectory)/app/Config/temp.yml" && \
                  mv "$(Build.SourcesDirectory)/app/Config/temp.yml" "$(Build.SourcesDirectory)/app/Config/config.yml"
                  config_path="$(Build.SourcesDirectory)/app/Config/config.yml"

                  echo "  Validating branch config block for '$BRANCH'..."
                  YQ_OUTPUT=$(yq e '.' "$config_path" 2>&1) || {
                    echo "##[error] YAML syntax error in branch config block:"
                    echo "$YQ_OUTPUT" | sed 's/^/    /'
                    exit 1
                  }
                  echo "  ✔ Branch config block — syntax OK"

                else
                  echo "##[error] config.yml not found and no eis-configuration entry found for '$applicationName'"
                  exit 1
                fi

                echo ""
                echo "  Checking required fields in config..."

                REQUIRED_FIELDS=(
                  IntegrationNode
                  IntegrationServer
                )

                ALL_FIELDS_OK=1
                for field in "${REQUIRED_FIELDS[@]}"; do
                  value=$(yq e ".$field // \"\"" "$config_path" | tr -d '[:space:]')
                  if [ -z "$value" ]; then
                    echo "  ✘ $field — MISSING or EMPTY"
                    ALL_FIELDS_OK=0
                  else
                    echo "  ✔ $field — OK ($value)"
                  fi
                done

                if [ "$ALL_FIELDS_OK" -eq 0 ]; then
                  echo ""
                  echo "##[error] One or more required fields are missing or empty in config."
                  exit 1
                fi

                echo ""
                echo "  Resolving Deploy and Cache flags..."

                DEPLOY=$(yq e ".Deploy" "$config_path" | tr -d '[:space:]')
                CACHE_PRESENT=$(yq e ".Cache // [] | length > 0" "$config_path" | tr -d '[:space:]')

                if [[ "$DEPLOY" =~ ^(false|False)$ ]]; then
                  DEPLOY="false"
                else
                  DEPLOY="true"
                fi

                if [[ "$CACHE_PRESENT" =~ ^(true|True)$ ]]; then
                  CACHE_PRESENT="true"
                else
                  CACHE_PRESENT="false"
                fi

                if [[ "$DEPLOY" != "true" && "$DEPLOY" != "false" ]]; then
                  echo "##[error] Invalid Deploy flag value in config: '$DEPLOY'"
                  exit 1
                fi

                echo "  ✔ DeployFlag  = $DEPLOY"
                echo "  ✔ CacheFlag   = $CACHE_PRESENT"

                echo ""
                echo "========= Branch-specific config validation passed ========="

                echo "##vso[task.setvariable variable=DeployFlag;isOutput=true]$DEPLOY"
                echo "##vso[task.setvariable variable=CacheFlag;isOutput=true]$CACHE_PRESENT"


  # ============== APPROVAL STAGE (PR → main only) ============
  - stage: Approval_Stage
    displayName: PR Approval (main)
    pool:
      name: TFS-RH-1
    dependsOn: Validation_Stage
    # Runs only when the PR's target branch is main
    condition: |
      and(
        succeeded('Validation_Stage'),
        eq(dependencies.Validation_Stage.outputs['Validation_Job.val_task.IsPRToMain'], 'true')
      )

    jobs:
      - deployment: Approval_Gate
        displayName: Waiting for Approval
        # ⚠️  Create an Environment named "main-approval" in Azure DevOps
        #     and add your Approvers under:
        #     Pipelines → Environments → main-approval → Approvals and checks
        environment: main-approval
        strategy:
          runOnce:
            deploy:
              steps:
                - task: CmdLine@2
                  displayName: Approval granted — proceeding
                  inputs:
                    script: |
                      echo "✔ PR to main approved. Pipeline may continue."


  # ================= BUILD STAGE =================
  - stage: Build
    displayName: Build Stage
    dependsOn:
      - Validation_Stage
      - Approval_Stage   # waits for approval when applicable
    pool:
      name: TFS-RH-1
    condition: |
      and(
        succeeded('Validation_Stage'),
        or(
          # Approval stage was skipped (not a PR to main) — proceed normally
          eq(stageDependencies.Approval_Stage.result, 'Skipped'),
          # Approval stage ran and was approved
          succeeded('Approval_Stage')
        )
      )

    jobs:
      - job: Build_Job
        displayName: Agent Build job
        workspace:
          clean: all

        steps:

          - checkout: self
            path: s/app

          - checkout: git://devops_testing/eis-configuration@refs/heads/config
            path: s/eis-configurations

          - task: CmdLine@2
            displayName: Building Bar file
            env:
              BRANCH: $(Build.SourceBranchName)
            inputs:
              script: |
                set -e
                . /opt/IBM/ace/server/bin/mqsiprofile

                applicationName=$(ls -1 "$(Build.SourcesDirectory)/app" | grep -vE "Config|README.md|azure-pipelines.yml" | tail -n 1)

                mkdir -p "$(Build.SourcesDirectory)/app/Config"

                yq e ".$applicationName | select(. !=null)" \
                  "$(Build.SourcesDirectory)/eis-configurations/${BRANCH}_config.yml" \
                  > "$(Build.SourcesDirectory)/app/Config/config_eis_configuration.yml"

                if [ -s "$(Build.SourcesDirectory)/app/Config/config_eis_configuration.yml" ]; then
                  config_path="$(Build.SourcesDirectory)/app/Config/config_eis_configuration.yml"
                  yq -i ".ApplicationName = \"$applicationName\"" "$config_path"
                  cp "$config_path" "$(Build.BinariesDirectory)/config.yml"
                else
                  yq e ".$BRANCH" "$(Build.SourcesDirectory)/app/Config/config.yml" \
                    > "$(Build.SourcesDirectory)/app/Config/temp.yml" &&
                  mv "$(Build.SourcesDirectory)/app/Config/temp.yml" "$(Build.SourcesDirectory)/app/Config/config.yml"
                  config_path="$(Build.SourcesDirectory)/app/Config/config.yml"
                  yq -i ".ApplicationName = \"$applicationName\"" "$config_path"
                  cp "$config_path" "$(Build.BinariesDirectory)/config.yml"
                fi

                override_path=""
                if [ -f "$(Build.SourcesDirectory)/eis-configurations/${BRANCH}_override.yml" ]; then
                  yq ".$applicationName | to_entries[] | .key + \" = \" + .value" \
                    "$(Build.SourcesDirectory)/eis-configurations/${BRANCH}_override.yml" \
                    > "$(Build.SourcesDirectory)/app/Config/override.properties"
                  override_path="$(Build.SourcesDirectory)/app/Config/override.properties"
                fi

                if [ -s "$override_path" ]; then
                  ibmint package \
                    --input-path "$(Build.SourcesDirectory)/app" \
                    --output-bar-file "$(Build.BinariesDirectory)/$applicationName.bar" \
                    --java-version 8 \
                    --overrides-file "$override_path"
                else
                  ibmint package \
                    --input-path "$(Build.SourcesDirectory)/app" \
                    --output-bar-file "$(Build.BinariesDirectory)/$applicationName.bar" \
                    --java-version 8
                fi

                mqsireadbar -b "$(Build.BinariesDirectory)/$applicationName.bar" -r \
                  | grep "=" | sed -e 's/^[[:space:]]*//' \
                  > "$(Build.BinariesDirectory)/override.properties"


          - task: CopyFiles@2
            inputs:
              SourceFolder: $(Build.BinariesDirectory)
              TargetFolder: $(Build.ArtifactStagingDirectory)
              OverWrite: true

          - task: PublishBuildArtifacts@1
            inputs:
              PathtoPublish: $(Build.ArtifactStagingDirectory)
              ArtifactName: drop

          - task: CmdLine@2
            displayName: Display override.properties
            condition: always()
            inputs:
              script: |
                OVERRIDE_FILE="$(Build.BinariesDirectory)/override.properties"
                if [ -f "$OVERRIDE_FILE" ]; then
                  echo "=========override.properties contents ========="
                  cat "$OVERRIDE_FILE"
                  echo "==============================================="
                else
                  echo "ERROR : override.properties not found at $OVERRIDE_FILE"
                fi

  # ================= RELEASE STAGE =================
  - stage: Release
    displayName: Deploy Stage
    pool:
      name: TFS-RH-1
    dependsOn:
      - Validation_Stage
      - Approval_Stage
      - Build
    condition: |
      and(
        succeeded('Build'),
        eq(dependencies.Validation_Stage.outputs['Validation_Job.val_task.DeployFlag'], 'true'),
        ne(variables['Build.SourceBranchName'], 'main'),
        or(
          eq(stageDependencies.Approval_Stage.result, 'Skipped'),
          succeeded('Approval_Stage')
        )
      )

    jobs:
      - deployment: DeployApp
        displayName: Deployment Job
        environment: $(Build.SourceBranchName)
        workspace:
          clean: all

        strategy:
          runOnce:
            deploy:
              steps:

                - download: current
                  artifact: drop

                - task: CmdLine@2
                  displayName: Deploying Bar File
                  env:
                    BRANCH: $(Build.SourceBranchName)
                  inputs:
                    workingDirectory: $(Pipeline.Workspace)/drop
                    script: |
                      set -e
                      . /opt/IBM/ace/server/bin/mqsiprofile

                      IntegrationNode=($(yq e ".IntegrationNode" config.yml))
                      ApplicationName=$(yq e ".ApplicationName" config.yml)
                      IntegrationServer=($(yq e ".IntegrationServer" config.yml))

                      broker_files=()

                      for node in "${IntegrationNode[@]}"; do
                        for broker_file in /home/devops/broker/$BRANCH/${node}*; do
                          fname=$(basename "$broker_file")
                          if [[ $fname =~ ^${node}_([0-9]+)\.broker$ ]]; then
                            broker_files+=("$broker_file")
                          fi
                        done
                      done

                      if [ ${#broker_files[@]} -eq 0 ]; then
                        echo "Error: No Integration Node found for $IntegrationNode"
                        exit 1
                      fi

                      for broker_file in "${broker_files[@]}"; do
                        servers=($(mqsilist -n "$broker_file" -w 5 | grep "running" | grep "Integration" | cut -d"'" -f2))

                        if [ ${#servers[@]} -eq 0 ]; then
                          echo "Error: Not able to access $broker_file or no Integration Server is running"
                          exit 1
                        fi

                        for server in "${IntegrationServer[@]}"; do
                          if printf '%s\n' "${servers[@]}" | grep -qx "$server"; then
                            host=$(grep host "$broker_file" | awk -F'"' '{print $4}')
                            echo "HOST: $host , IntegrationNode: $fname , IntegrationServer: $server"

                            DEPLOY_LOG=$(mktemp)

                            ibmint deploy \
                              --input-bar-file "$ApplicationName.bar" \
                              --integration-node-file "$broker_file" \
                              --output-server "$server" 2>&1 | tee "$DEPLOY_LOG"

                            ERROR_BIPS=$(grep -oP 'BIP\d+E' "$DEPLOY_LOG" || true)
                            if [ -n "$ERROR_BIPS" ]; then
                              echo ""
                              echo "##[error] Deployment FAILED — BIP Error codes detected:"
                              rm -f "$DEPLOY_LOG"
                              exit 1
                            fi

                            echo "Deployment successful — no BIP Error codes found."
                            rm -f "$DEPLOY_LOG"

                          else
                            echo " Integration server $server name is incorrect or not running"
                            exit 1
                          fi
                        done
                      done

  # ================= CACHE STAGE =================
  - stage: Cache
    displayName: CACHE
    pool:
      name: TFS-RH-1
    dependsOn:
      - Validation_Stage
      - Approval_Stage
      - Build
    condition: |
      and(
        succeeded('Validation_Stage'),
        eq(dependencies.Validation_Stage.outputs['Validation_Job.val_task.CacheFlag'], 'true'),
        or(
          eq(dependencies.Validation_Stage.outputs['Validation_Job.val_task.DeployFlag'], 'false'),
          succeeded('Build')
        ),
        ne(variables['Build.SourceBranchName'], 'main'),
        or(
          eq(stageDependencies.Approval_Stage.result, 'Skipped'),
          succeeded('Approval_Stage')
        )
      )

    jobs:
      - job: Cache_Job
        displayName: CACHE UPDATE
        workspace:
          clean: all

        steps:

          - download: current
            artifact: drop

          - task: CmdLine@2
            displayName: Update cache in Database
            env:
              BRANCH: $(Build.SourceBranchName)
            inputs:
              workingDirectory: $(Pipeline.Workspace)/drop/
              script: |
                source ~/.bashrc
                set -e
                if [ ! -f config.yml ]; then
                  echo "config.yml file was not found !!"
                  exit 1
                fi

                yq ".Cache[].Query" config.yml | while IFS= read -r SQL; do
                  echo "Executing SQL: $SQL"
                  OUTPUT=$(echo "$SQL" | isql "$BRANCH" "$DB_USER" "$DB_PASS" 2>&1)
                  STATUS=$?
                  if [[ $STATUS -eq 0 ]] && echo "$OUTPUT" | grep -qi "SQLRowCount"; then
                    echo "SUCCESS: Query executed"
                  else
                    echo "FAILED: Query did not execute"
                    exit 1
                  fi
                done

          - task: CmdLine@2
            displayName: Update Cache in Server
            env:
              BRANCH: $(Build.SourceBranchName)
            inputs:
              workingDirectory: $(Pipeline.Workspace)/drop/
              script: |
                set -e

                IntegrationNode=($(yq e ".IntegrationNode" config.yml))
                broker_files=()

                for node in "${IntegrationNode[@]}"; do
                  for broker_file in /home/devops/broker/$BRANCH/${node}*; do
                    fname=$(basename "$broker_file")
                    if [[ $fname =~ ^${node}_([0-9]+)\.broker$ ]]; then
                      broker_files+=("$broker_file")
                    fi
                  done
                done

                if [ ${#broker_files[@]} -eq 0 ]; then
                  echo "Error: No Integration Node found for $IntegrationNode"
                  exit 1
                fi

                for broker_file in "${broker_files[@]}"; do
                  host=$(cat "$broker_file" | grep host | cut -d"\"" -f4)
                  if yq -e ".Cache" config.yml >/dev/null 2>&1; then
                    response=$(curl -s -k -X POST http://"$host":8002/cache/v1/loadCache \
                    -H "Content-Type: application/json" \
                    -d "$(yq -o=json ".Cache | map({\"FIELD_NAME\": .FIELD_NAME, \"FIELD_VALUE\": .FIELD_VALUE})" config.yml)")
                    if [[ "$response" != *'"RESPONSE":"success"'* ]]; then
                      echo "Cache load failed: $response"
                      exit 1
                    fi
                    echo "Cache load successful on $host"
                    echo "$(yq -o=json ".Cache | map({\"FIELD_NAME\": .FIELD_NAME, \"FIELD_VALUE\": .FIELD_VALUE})" config.yml)"
                  fi
                done
